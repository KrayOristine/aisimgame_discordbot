{
  "name": "roleplay-ai-sim",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "vite build",
    "run:test": "NODE_ENV=development node ./dist/index.js",
    "run:prod": "NODE_ENV=production node ./dist/index.js",
