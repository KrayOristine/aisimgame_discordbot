  "dependencies": {
    "@discordjs/builders": "1.14.1",
    "@discordjs/collection": "2.1.1",
    "@discordjs/core": "2.4.0",
    "@discordjs/formatters": "0.6.2",
    "@discordjs/rest": "2.6.1",
    "@discordjs/ws": "2.0.4",
    "@google/genai": "^1.46.0",
    "@mongodb-js/zstd": "7.0.0",
    "arktype": "2.2.0",
    "bson": "7.2.0",
    "discord.js": "14.26.2",
    "lodash": "4.17.23",
    "mongodb": "7.1.1",
    "pako": "2.1.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "xxhash-wasm": "1.1.0"
  },
  "devDependencies": {
    "@types/lodash": "4.17.24",
