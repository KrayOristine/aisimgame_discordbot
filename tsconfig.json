{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "rootDir": ".",
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "nodenext",
    "moduleDetection": "auto",
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "allowUnusedLabels": false,
    "strict": true,
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"],
    },
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["./src/**/*.ts"]
}
